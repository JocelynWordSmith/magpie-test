# Magpie — local environment overrides.
# Copy this file to `.env` and edit. None of these are required;
# defaults are documented next to each.

# Local port for `python3 run.py`. Default: 8086
# MAGPIE_PORT=8086

# Absolute or relative path to your gallery directory.
# Must contain a README.md and one or more <slug>.md report files.
# Used by both `run.py` (local) and `build.py` (GitHub Pages build).
# Default: ./sample (the bundled demo)
# MAGPIE_GALLERY_PATH=/path/to/your/gallery
